[Unit]
Description=AI Learning Site Sync API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/ai-learning-site/server
Environment=AI_SYNC_HOST=127.0.0.1
Environment=AI_SYNC_PORT=8090
Environment=AI_SYNC_DATA_DIR=/home/ubuntu/ai-learning-site/data
ExecStart=/usr/bin/python3 /home/ubuntu/ai-learning-site/server/sync_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
